<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#E7F9FC"
                android:centerColor="#D4EEF4"
                android:endColor="#F6E8C7" />
        </shape>
    </item>
    <item android:left="-120dp" android:top="-80dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:startColor="#55A5E7F2"
                android:endColor="#00A5E7F2" />
        </shape>
    </item>
    <item android:right="-90dp" android:bottom="-140dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="300dp"
                android:startColor="#44C7EFB2"
                android:endColor="#00C7EFB2" />
        </shape>
    </item>
</layer-list>
