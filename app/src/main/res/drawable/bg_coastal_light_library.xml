<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#E8F8FB"
                android:centerColor="#D7F1F5"
                android:endColor="#F7F0DC" />
        </shape>
    </item>
    <item android:top="-60dp" android:right="-60dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="220dp"
                android:startColor="#66A0E5F0"
                android:endColor="#00A0E5F0" />
        </shape>
    </item>
    <item android:left="-100dp" android:bottom="-120dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="280dp"
                android:startColor="#55EED8A1"
                android:endColor="#00EED8A1" />
        </shape>
    </item>
</layer-list>
